# ── Smart Classroom — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is in .gitignore — NEVER commit it.

# ── Groq LLM ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets & Drive ─────────────────────────────────────────────────────
# The ID from the Sheets URL: https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# Google Shared Drive folder ID where reports are uploaded
GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz

# Service account credentials JSON (inline, single line — use `jq -c . creds.json`)
GOOGLE_CREDS_JSON={"type":"service_account","project_id":"..."}

# ── Auth ──────────────────────────────────────────────────────────────────────
# Any strong random string — used to sign JWT tokens
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars

# ── Notifications (optional — leave blank to skip) ────────────────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP=whatsapp:+14155238886

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM=noreply@yourdomain.com

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Local path for persistent vector store (override for Cloud Run to /tmp/chromadb)
CHROMA_PERSIST_DIR=./data/chromadb

# ── GCP (for local dev using ADC) ────────────────────────────────────────────
# Only needed if GOOGLE_CREDS_JSON is not set
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
